{
  "name": "deploy-master",
  "version": "0.1.0",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "worker": "bun src/workers/index.ts",
    "seed": "bun src/scripts/seedAdmin.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:push": "prisma db push",
    "prisma:studio": "prisma studio",
    "infra:up": "docker compose -f docker-compose.infra.yml up -d",
    "infra:down": "docker compose -f docker-compose.infra.yml down",
    "dev:all": "concurrently \"npm run dev:web\" \"npm run dev:api\" \"npm run dev:worker\"",
    "dev:web": "cd ./web && bun run dev",
    "dev:api": "bun run dev",
    "dev:worker": "bun run worker"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "7",
    "@types/multer": "^2.1.0",
    "axios": "^1.7.0",
    "bcryptjs": "^3",
    "cors": "^2.8.5",
    "dayjs": "^1.11.13",
    "dockerode": "^4.0.2",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "reflect-metadata": "^0.2.2",
    "ws": "^8.21.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/cors": "^2.8.17",
    "@types/dockerode": "^3.3.31",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/ws": "^8.18.1",
    "concurrently": "^10.0.3",
    "prisma": "7"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
