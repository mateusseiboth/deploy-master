# ── App ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Banco de controle (metadados do sistema) ──────────────────────────────
DATABASE_URL="postgresql://deploy:deploy@localhost:5432/deploy_master?schema=public"
# Transação interativa do Prisma (ms). Aumente se o banco for remoto/lento (P2028).
DB_TX_TIMEOUT_MS=15000
DB_TX_MAX_WAIT_MS=5000

# ── Postgres host p/ provisionar bancos efêmeros dos ambientes ─────────────
# Cada ambiente recebe um banco isolado criado neste servidor.
EPHEMERAL_PG_HOST="localhost"
EPHEMERAL_PG_PORT=5432
EPHEMERAL_PG_ADMIN_USER="postgres"
EPHEMERAL_PG_ADMIN_PASSWORD="postgres"

# ── Fila / Cache (SQLite, sem Redis) ───────────────────────────────────────
# Fila de jobs persistida em arquivo SQLite (bun:sqlite, nativo do runtime).
QUEUE_DB_PATH="./data/queue.sqlite"
# Cache: "memory" (in-process) ou "sqlite"
CACHE_DRIVER="memory"
CACHE_DB_PATH="./data/cache.sqlite"

# ── Auth ───────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET="change-me-access"
JWT_REFRESH_SECRET="change-me-refresh"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"

# ── Docker ─────────────────────────────────────────────────────────────────
DOCKER_SOCKET="/var/run/docker.sock"
# Diretório de trabalho para clones/builds dos ambientes
WORKSPACE_DIR="/tmp/deploy-master/workspaces"

# ── DNS (Pi-hole v6) e Proxy ───────────────────────────────────────────────
# IMPORTANTE: estes valores são apenas a SEMENTE inicial. A configuração oficial
# de Pi-hole, GitLab, proxy e backup é cadastrada pelo ADMIN no banco (tabela
# system_settings, rota PUT /api/settings, tela "Configurações"). Edite por lá.
# Pi-hole v6 autentica com a SENHA do admin (não há mais API token). Use a URL
# RAIZ (sem /admin); a API fica em <PIHOLE_BASE_URL>/api.
PIHOLE_BASE_URL="http://localhost:8081"
PIHOLE_PASSWORD="change-me"
# IP do servidor de proxy reverso para onde os hostnames apontam (host do Traefik)
REVERSE_PROXY_IP="20.0.0.128"
TRAEFIK_NETWORK="traefik-public"
BASE_DOMAIN="qa.local"

# ── GitLab (token geral; projetos buscam pela API) ─────────────────────────
GITLAB_BASE_URL="https://gitlab.example.com"
GITLAB_API_TOKEN="change-me"

# ── Backup automático do PostgreSQL de produção ────────────────────────────
# pg_dump completo de TODOS os bancos do servidor, gravado na pasta destino.
PROD_BACKUP_DB_URL="postgresql://postgres:postgres@prod-db:5432/postgres"
PROD_BACKUP_DIR="/var/backups/postgres"
PROD_BACKUP_INTERVAL_HOURS=24
PROD_BACKUP_ENABLED="false"

# ── Proxy reverso / certificado (estratégias do projeto) ───────────────────
REVERSE_PROXY_PROVIDER="traefik"   # traefik | caddy
CERTIFICATE_PROVIDER="internal-ca" # internal-ca | lets-encrypt

# ── Pi-hole (docker-compose.infra.yml) ─────────────────────────────────────
PIHOLE_WEBPASSWORD="admintest"     # senha do admin da web (v6)
